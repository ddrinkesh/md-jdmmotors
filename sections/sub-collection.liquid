{{ 'sub-collection.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media screen and (max-width: 749px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobi }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobi }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign sub_collection_metafield = collection.metafields.custom.sub_collections
  assign sub_collections = sub_collection_metafield.value
  assign sidebar_menu = section.settings.sidebar_menu
  assign image_ratio = '75%'

  if section.settings.image_ratio == 'portrait'
    assign image_ratio = '125%'
  elsif section.settings.image_ratio == 'square'
    assign image_ratio = '100%'
  endif
-%}

<div class="section-{{ section.id }} section-{{ section.id }}-padding section-{{ section.id }}-margin color-{{ section.settings.color_scheme }} gradient section-main-box sub-collection-main">
  <div class="page-width">
    {% if section.settings.heading != blank or section.settings.sec_text != blank %}
      <div class="sec-head text-align-{{ section.settings.text_align }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {% if section.settings.heading != blank %}
          <h2 class="sec-title">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.sec_text != blank %}
          <div class="sec-text">{{ section.settings.sec_text }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="sub-collection-layout{% if sidebar_menu.links != blank %} sub-collection-layout--with-sidebar{% endif %}">
      {% if sidebar_menu.links != blank %}
        <aside class="brands-main-collection-sidebar" aria-label="{{ section.settings.sidebar_heading | default: 'Brands' | escape }}">
          {% if section.settings.sidebar_heading != blank %}
            <h3 class="brands-main-collection-sidebar__title">{{ section.settings.sidebar_heading }}</h3>
          {% endif %}

          <div class="brands-main-collection-menu">
            {% for parent_link in sidebar_menu.links %}
              {%- liquid
                assign parent_object = parent_link.object
                assign parent_brand = parent_object.metafields.custom.brand.value
                assign parent_image = parent_object.metafields.custom.sidebar_image.value
                assign is_active_parent = parent_link.active

                if parent_image == blank
                  assign parent_image = parent_brand.brand_logo.value
                endif

                if parent_image == blank
                  assign parent_image = parent_brand.logo.value
                endif

                if parent_image == blank
                  assign parent_image = parent_brand.image.value
                endif

                if parent_image == blank
                  assign parent_image = parent_object.metafields.custom.logo.value
                endif

                if parent_image == blank
                  assign parent_image = parent_object.metafields.custom.image.value
                endif

                if parent_image == blank
                  assign parent_image = parent_object.featured_image
                endif

                if parent_image == blank
                  assign parent_image = parent_object.image
                endif

                if is_active_parent == false and parent_link.links != blank
                  for child_link in parent_link.links
                    if child_link.active
                      assign is_active_parent = true
                    endif
                  endfor
                endif
              -%}

              <div class="brands-main-collection-menu__item{% if is_active_parent %} is-active{% endif %}">
                <a
                  href="{{ parent_link.url }}"
                  class="brands-main-collection-menu__link{% if is_active_parent %} is-active{% endif %}"
                  {% if parent_link.links != blank %}
                    data-brands-sidebar-toggle
                    aria-expanded="{% if is_active_parent %}true{% else %}false{% endif %}"
                  {% endif %}
                >
                  <span class="brands-main-collection-menu__brand">
                    <span class="brands-main-collection-menu__logo">
                      {% if parent_image != blank %}
                        {{ parent_image | image_url: width: 120 | image_tag: loading: 'lazy', class: 'brands-main-collection-menu__logo-img', widths: '60, 90, 120', alt: parent_link.title }}
                      {% else %}
                        {{ parent_link.title }}
                      {% endif %}
                    </span>
                    <span class="brands-main-collection-menu__name">{{ parent_link.title }}</span>
                  </span>
                  <span class="brands-main-collection-menu__arrow" aria-hidden="true">{{ 'icon-caret.svg' | inline_asset_content }}</span>
                </a>

                {% if parent_link.links != blank %}
                  <div class="brands-main-collection-submenu" data-brands-sidebar-submenu aria-hidden="{% if is_active_parent %}false{% else %}true{% endif %}">
                    {% for child_link in parent_link.links %}
                      {%- liquid
                        assign child_object = child_link.object
                        assign child_handle = child_link.title | handleize
                        assign child_image = blank

                        if child_handle == 'engine' or child_handle == 'engines'
                          assign child_image = parent_brand.engine.value.image.value
                        elsif child_handle == 'transmission' or child_handle == 'transmissions'
                          assign child_image = parent_brand.transmissions.value.image.value
                        elsif child_handle == 'accessory' or child_handle == 'accessories'
                          assign child_image = parent_brand.accessories.value.image.value
                        elsif child_handle == 'front-clip' or child_handle == 'front-clips'
                          assign child_image = parent_brand.front_clips.value.image.value
                        elsif child_handle == 'car' or child_handle == 'cars'
                          assign child_image = parent_brand.cars.value.image.value
                        endif

                        if child_image == blank
                          assign child_image = child_object.metafields.custom.sidebar_image.value
                        endif

                        if child_image == blank
                          assign child_image = child_object.metafields.custom.image.value
                        endif

                        if child_image == blank
                          assign child_image = child_object.featured_image
                        endif

                        if child_image == blank
                          assign child_image = child_object.image
                        endif
                      -%}

                      <a href="{{ child_link.url }}" class="brands-main-collection-submenu__link{% if child_link.active %} is-active{% endif %}">
                        <span class="brands-main-collection-submenu__image">
                          {% if child_image != blank %}
                            {{ child_image | image_url: width: 90 | image_tag: loading: 'lazy', class: 'brands-main-collection-submenu__img', widths: '45, 60, 90', alt: child_link.title }}
                          {% endif %}
                        </span>
                        <span>{{ child_link.title }}</span>
                      </a>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        </aside>
      {% endif %}

      <div class="sub-collection-content">
        {% if sub_collections != blank %}
          <ul class="sub-collection-list sub-collection-list--{{ section.settings.card_view }}" style="--sub-collection-columns-desktop: {{ section.settings.columns_desktop }}; --sub-collection-columns-mobile: {{ section.settings.columns_mobile }}; --sub-collection-image-ratio: {{ image_ratio }};" role="list">
            {% for sub_collection in sub_collections %}
              <li class="sub-collection-card {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %}data-cascade style="--animation-order: {{ forloop.index }};"{% endif %}>
                <a href="{{ sub_collection.url }}" class="sub-collection-card__link color-{{ section.settings.card_color_scheme }} gradient">
                  <span class="sub-collection-card__media">
                    {% if sub_collection.featured_image != blank %}
                      {{ sub_collection.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'sub-collection-card__image', widths: '300, 450, 600, 750, 900', sizes: '(min-width: 990px) calc((100vw - 10rem) / 3), (min-width: 750px) calc((100vw - 8rem) / 2), calc(100vw - 3rem)', alt: sub_collection.featured_image.alt | default: sub_collection.title }}
                    {% else %}
                      {{ 'collection-apparel-1' | placeholder_svg_tag: 'placeholder-svg sub-collection-card__placeholder' }}
                    {% endif %}
                  </span>
                  <span class="sub-collection-card__content">
                    <span>
                      <span class="sub-collection-card__title">{{ sub_collection.title }}</span>
                      {% if section.settings.show_description and sub_collection.description != blank %}
                        <span class="sub-collection-card__description">{{ sub_collection.description | strip_html | truncatewords: 18 }}</span>
                      {% endif %}
                      {% if section.settings.show_product_count %}
                        {%- liquid
                          assign available_products_count = 0
                          for product in sub_collection.products
                            if product.available
                              assign available_products_count = available_products_count | plus: 1
                            endif
                          endfor
                        -%}
                        <span class="sub-collection-card__count">{{ sub_collection.all_products_count }} products | {{ available_products_count }} available</span>
                      {% endif %}
                    </span>
                    <span class="sub-collection-card__arrow" aria-hidden="true">{{ 'icon-caret.svg' | inline_asset_content }}</span>
                  </span>
                </a>
              </li>
            {% endfor %}
          </ul>
        {% elsif section.settings.empty_text != blank %}
          <p class="sub-collection-empty">{{ section.settings.empty_text }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script>
  if (!window.brandsCollectionSidebarAccordion) {
    window.brandsCollectionSidebarAccordion = true;

    function getSubmenu(item) {
      return item && item.querySelector('[data-brands-sidebar-submenu]');
    }

    function setInitialSidebarState() {
      document.querySelectorAll('.brands-main-collection-menu__item').forEach(function(item) {
        var submenu = getSubmenu(item);
        if (!submenu) return;

        if (item.classList.contains('is-active')) {
          submenu.style.height = 'auto';
          submenu.style.opacity = '1';
          submenu.setAttribute('aria-hidden', 'false');
        } else {
          submenu.style.height = '0px';
          submenu.style.opacity = '0';
          submenu.setAttribute('aria-hidden', 'true');
        }
      });
    }

    function openSidebarItem(item, toggle, submenu) {
      item.classList.add('is-active');
      toggle.classList.add('is-active');
      toggle.setAttribute('aria-expanded', 'true');
      submenu.setAttribute('aria-hidden', 'false');
      submenu.style.height = '0px';
      submenu.style.opacity = '0';

      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          submenu.style.height = submenu.scrollHeight + 'px';
          submenu.style.opacity = '1';
        });
      });

      submenu.addEventListener('transitionend', function onTransitionEnd(event) {
        if (event.propertyName !== 'height') return;
        submenu.style.height = 'auto';
        submenu.removeEventListener('transitionend', onTransitionEnd);
      });
    }

    function closeSidebarItem(item) {
      var toggle = item.querySelector('[data-brands-sidebar-toggle]');
      var submenu = getSubmenu(item);

      if (!submenu || !item.classList.contains('is-active')) return;

      item.classList.remove('is-active');

      if (toggle) {
        toggle.classList.remove('is-active');
        toggle.setAttribute('aria-expanded', 'false');
      }

      submenu.style.height = submenu.scrollHeight + 'px';
      submenu.style.opacity = '1';

      requestAnimationFrame(function() {
        submenu.style.height = '0px';
        submenu.style.opacity = '0';
        submenu.setAttribute('aria-hidden', 'true');
      });
    }

    document.addEventListener('click', function(event) {
      var toggle = event.target.closest('[data-brands-sidebar-toggle]');

      if (!toggle || event.metaKey || event.ctrlKey || event.shiftKey || event.button !== 0) {
        return;
      }

      var item = toggle.closest('.brands-main-collection-menu__item');
      var menu = toggle.closest('.brands-main-collection-menu');
      var submenu = getSubmenu(item);

      if (!item || !menu || !submenu) {
        return;
      }

      event.preventDefault();

      var shouldOpen = !item.classList.contains('is-active');
      var allItems = menu.querySelectorAll('.brands-main-collection-menu__item');

      allItems.forEach(function(menuItem) {
        closeSidebarItem(menuItem);
      });

      if (shouldOpen) {
        openSidebarItem(item, toggle, submenu);
      }
    });

    setInitialSidebarState();
  }
</script>

{% schema %}
{
  "name": "Sub Collection",
  "tag": "section",
  "class": "sub-collection-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Sub Collections"
    },
    {
      "type": "richtext",
      "id": "sec_text",
      "label": "Content"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "richtext",
      "id": "empty_text",
      "label": "Empty text",
      "default": "<p>Add collections to this collection's Sub Collections metafield.</p>"
    },
    {
      "type": "header",
      "content": "Sidebar"
    },
    {
      "type": "inline_richtext",
      "id": "sidebar_heading",
      "label": "Sidebar heading",
      "default": "Brands"
    },
    {
      "type": "link_list",
      "id": "sidebar_menu",
      "label": "Sidebar menu",
      "info": "Use parent menu items for brands and nested submenu items for linked collections. Images are pulled from linked collection images or custom collection metafields."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "Card color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "card_view",
      "label": "Card view",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        },
        {
          "value": "list",
          "label": "List"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Columns desktop",
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns mobile",
      "default": "1",
      "options": [
        {
          "value": "1",
          "label": "1 column"
        },
        {
          "value": "2",
          "label": "2 columns"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "default": "adapt",
      "options": [
        {
          "value": "adapt",
          "label": "Landscape"
        },
        {
          "value": "square",
          "label": "Square"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show collection description",
      "default": false
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section Settings For Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobi",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 25
    },
    {
      "type": "range",
      "id": "padding_bottom_mobi",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 25
    }
  ],
  "presets": [
    {
      "name": "Sub Collection"
    }
  ]
}
{% endschema %}
