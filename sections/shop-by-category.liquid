{{ 'shop-by-category.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top | times: 0.75 | round }}px;
      margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobi }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobi }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }} section-{{ section.id }}-padding section-{{ section.id }}-margin color-{{ section.settings.color_scheme }} gradient section-main-box shop-by-category-main">
  <div class="page-width">

    {% if section.settings.heading != blank or section.settings.sec_text != blank %}
      <div class="sec-head text-align-{{ section.settings.text_align }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {% if section.settings.heading != blank %}
          <h2 class="sec-title">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.sec_text != blank %}
          <div class="sec-text">{{ section.settings.sec_text }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="shop-by-category-grid">
        {% for block in section.blocks %}
          {%- assign card_class = 'shop-cat-card' -%}
          {%- if block.settings.is_featured -%}
            {%- assign card_class = 'shop-cat-card shop-cat-card--featured' -%}
          {%- endif -%}

          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="{{ card_class }}" {{ block.shopify_attributes }} aria-label="{{ block.settings.title | default: 'Category' | strip_html | escape }}">
          {%- else -%}
            <div class="{{ card_class }}" {{ block.shopify_attributes }}>
          {%- endif -%}

            <div class="shop-cat-card__media">
              {%- if block.settings.image != blank -%}
                {%- assign img_alt = block.settings.image.alt | default: block.settings.title | default: 'Category image' | strip_html -%}
                {{ block.settings.image | image_url: width: 1200 | image_tag:
                  loading: 'lazy',
                  class: 'shop-cat-card__image',
                  widths: '320, 480, 640, 800, 1000, 1200',
                  sizes: '(min-width: 750px) 50vw, 100vw',
                  alt: img_alt
                }}
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg shop-cat-card__image' }}
              {%- endif -%}
              <span class="shop-cat-card__overlay" aria-hidden="true"></span>
            </div>

            <div class="shop-cat-card__content">
              <div class="shop-cat-card__text">
                {% if block.settings.label != blank %}
                  <span class="shop-cat-card__label">{{ block.settings.label }}</span>
                {% endif %}
                {% if block.settings.title != blank %}
                  <h3 class="shop-cat-card__title">{{ block.settings.title }}</h3>
                {% endif %}
              </div>

              <span class="shop-cat-card__btn" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8.35083 2.845L1.17833 10.0175L0 8.83917L7.17167 1.66667H0.850834V0H10.0175V9.16667H8.35083V2.845Z" fill="currentColor"/>
                </svg>
              </span>
            </div>

          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        {% endfor %}
      </div>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Shop By Category",
  "tag": "section",
  "class": "shop-by-category-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Highlighted text should be added in bold format, and the bold text will appear in red color."   
    },    
    {
      "type": "richtext",
      "id": "sec_text",
      "label": "Content"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section Settings For Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobi",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 25
    },
    {
      "type": "range",
      "id": "padding_bottom_mobi",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 25
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [        
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "inline_richtext",
          "id": "label",
          "label": "Small label",
          "info": "Example: 240+ In Stock"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "header",
          "content": "Note:",
          "info": "First card will be featured with larger size. other card will be of normal size."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop By Category",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "label": "240+ In Stock",
            "title": "Engines"           
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "180+ In Stock",
            "title": "Transmissions"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "Wheels • Interiors • Misc",
            "title": "Accessories"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "60+ In Stock",
            "title": "Front Clips"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "JDM Imports",
            "title": "Wheels"
          }
        }
      ]
    }
  ]
}
{% endschema %}
