{% style %}
    .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobi }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobi }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

{% endstyle %}

{{ 'breadcrumbs.css' | asset_url | stylesheet_tag }}

<div class="section--{{ section.id }} gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding {% if template.suffix == 'outfit' %} {% unless customer %}hidden{% endunless %}{% endif %}">
    <div class="page-width">
        {% render 'breadcrumbs' %}
    </div>
</div>





{% schema %}
  {
    "name": "Breadcrumbs",
    "settings": [
      {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Breadcrumbs"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobi",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top for Mobile",
      "default": 25
    },
    {
      "type": "range",
      "id": "padding_bottom_mobi",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom for Mobile",
      "default": 25
    }
    ],
     "presets": [
    {
      "name": "Breadcrumbs"
    }
  ]
  }
{% endschema %}