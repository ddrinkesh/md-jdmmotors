{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer class="footer color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="footer-main">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'brand' %}
            <div class="footer-block footer-brand" {{ block.shopify_attributes }}>
              <a href="{{ routes.root_url }}" class="footer-brand__logo" aria-label="{{ shop.name | escape }}">
                {% if block.settings.logo != blank %}
                  {{
                    block.settings.logo
                    | image_url: width: 360
                    | image_tag: loading: 'lazy', widths: '160, 220, 320, 360', alt: shop.name
                  }}
                {% else %}
                  <img src="{{ 'footer-logo-base.png' | asset_url }}" alt="{{ shop.name | escape }}" loading="lazy" width="164" height="60">
                {% endif %}
              </a>

              {% if block.settings.description != blank %}
                <div class="footer-brand__text rte">{{ block.settings.description }}</div>
              {% endif %}

              <div class="footer-brand__map">
                {% if block.settings.google_map_embed != blank %}
                  {{ block.settings.google_map_embed }}
                {% else %}
                  <iframe src="https://www.google.com/maps?q=5021%20Herzel%20Place%2C%20Beltsville%2C%20MD%2020705%2C%20USA&amp;output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Store location"></iframe>
                {% endif %}
              </div>
            </div>

          {% when 'menu' %}
            <div class="footer-block footer-menu" {{ block.shopify_attributes }}>
              <details class="footer-menu__accordion" open>
                <summary class="footer-title footer-menu__summary">
                  <span>{{ block.settings.heading | default: 'Footer menu' }}</span>
                  <span class="footer-menu__icon" aria-hidden="true"></span>
                </summary>

                {% if block.settings.menu != blank and block.settings.menu.links.size > 0 %}
                  <ul class="footer-menu__list list-unstyled">
                    {% for link in block.settings.menu.links %}
                      <li><a href="{{ link.url }}" class="footer-link{% if link.active %} footer-link--active{% endif %}">{{ link.title | escape }}</a></li>
                    {% endfor %}
                  </ul>
                {% elsif block.settings.fallback_links == 'quick_links' %}
                  <ul class="footer-menu__list list-unstyled">
                    <li><a href="{{ routes.root_url }}" class="footer-link">Home</a></li>
                    <li><a href="{{ routes.all_products_collection_url }}" class="footer-link">Shop</a></li>
                    <li><a href="/pages/about-us" class="footer-link">About Us</a></li>
                    <li><a href="/pages/contact" class="footer-link">Contact</a></li>
                  </ul>
                {% elsif block.settings.fallback_links == 'policies' %}
                  <ul class="footer-menu__list list-unstyled">
                    <li><a href="/policies/terms-of-service" class="footer-link">Terms & Conditions</a></li>
                    <li><a href="/policies/privacy-policy" class="footer-link">Privacy Policy</a></li>
                    <li><a href="/policies/shipping-policy" class="footer-link">Shipping Policy</a></li>
                    <li><a href="/policies/refund-policy" class="footer-link">Return Policy</a></li>
                  </ul>
                {% elsif block.settings.fallback_links == 'categories' %}
                  <ul class="footer-menu__list list-unstyled">
                    <li><a href="{{ routes.all_products_collection_url }}" class="footer-link">Engines</a></li>
                    <li><a href="{{ routes.all_products_collection_url }}" class="footer-link">Transmissions</a></li>
                    <li><a href="{{ routes.all_products_collection_url }}" class="footer-link">Accessories</a></li>
                    <li><a href="{{ routes.all_products_collection_url }}" class="footer-link">Front Clips</a></li>
                    <li><a href="{{ routes.all_products_collection_url }}" class="footer-link">Cars</a></li>
                  </ul>
                {% endif %}
              </details>
            </div>

          {% when 'contact' %}
            <div class="footer-block footer-contact" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <h2 class="footer-title">{{ block.settings.heading }}</h2>
              {% endif %}
              <div class="footer-contact__list">
                {% if block.settings.phone != blank %}
                  <a href="tel:{{ block.settings.phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}" class="footer-contact__item">
                    <span class="footer-contact__icon">
                      <svg aria-hidden="true" focusable="false" viewBox="0 0 16 16"><path d="M11.742 8.565 15.919 12.742 13.805 14.856C13.436 15.223 12.999 15.513 12.517 15.709 12.036 15.906 11.52 16.005 11 16 6.168 16 0 9.832 0 5-.004 4.48.095 3.964.291 3.483.488 3.001.777 2.563 1.144 2.195L3.258.081 7.435 4.258l-2.75 2.75c.817 1.943 2.361 3.49 4.302 4.312l2.755-2.755ZM14.667 6.667H16A6.667 6.667 0 0 0 9.333 0v1.333A5.334 5.334 0 0 1 14.667 6.667ZM12 6.667h1.333a4 4 0 0 0-4-4V4A2.667 2.667 0 0 1 12 6.667Z"/></svg>
                    </span>
                    <span>{{ block.settings.phone }}</span>
                  </a>
                {% endif %}

                {% if block.settings.email != blank %}
                  <a href="mailto:{{ block.settings.email }}" class="footer-contact__item">
                    <span class="footer-contact__icon">
                      <svg aria-hidden="true" focusable="false" viewBox="0 0 16 15"><path d="M15.969 3.028 10.357 8.64A3.333 3.333 0 0 1 8 9.615a3.333 3.333 0 0 1-2.357-.975L.031 3.028C.021 3.133 0 3.229 0 3.333v8A3.337 3.337 0 0 0 3.333 14.667h9.334A3.337 3.337 0 0 0 16 11.333v-8c0-.104-.021-.2-.031-.305Z"/><path d="m9.415 7.697 6.089-6.09A3.335 3.335 0 0 0 12.667 0H3.333A3.335 3.335 0 0 0 .496 1.607l6.089 6.09A2.003 2.003 0 0 0 8 8.282c.53 0 1.039-.21 1.415-.585Z"/></svg>
                    </span>
                    <span>{{ block.settings.email }}</span>
                  </a>
                {% endif %}
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>

    {% assign brand_tags = section.settings.brand_tags | split: ',' %}
    {% if section.settings.brand_tags != blank %}
      <div class="footer-brands" aria-label="Brands">
        {% for brand in brand_tags %}
          {% assign brand_name = brand | strip %}
          {% if brand_name != blank %}
            <span class="footer-brands__item">{{ brand_name }}</span>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <div class="footer-bottom">
      {% if section.settings.copyright_text != blank %}
        <div class="footer-bottom__copyright">{{ section.settings.copyright_text }}</div>
      {% endif %}

      {% if section.settings.payment_enable %}
        <div class="footer-bottom__payment">
          <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
          <ul class="list list-payment" role="list">
            {% for type in shop.enabled_payment_types %}
              <li class="list-payment__item">{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    </div>
  </div>
</footer>

<script>
  (() => {
    const footer = document.currentScript.previousElementSibling;
    if (!footer || footer.dataset.footerAccordionReady === 'true') return;

    footer.dataset.footerAccordionReady = 'true';

    const mediaQuery = window.matchMedia('(max-width: 749px)');
    const accordions = Array.from(footer.querySelectorAll('.footer-menu__accordion'));

    const syncAccordions = () => {
      accordions.forEach((details) => {
        const summary = details.querySelector('.footer-menu__summary');
        const list = details.querySelector('.footer-menu__list');
        if (!summary || !list) return;

        if (mediaQuery.matches) {
          details.open = false;
          summary.setAttribute('role', 'button');
          summary.removeAttribute('tabindex');
          summary.setAttribute('aria-expanded', 'false');
          list.style.maxHeight = '0px';
        } else {
          details.open = true;
          summary.removeAttribute('role');
          summary.setAttribute('tabindex', '-1');
          summary.setAttribute('aria-expanded', 'true');
          list.style.maxHeight = '';
        }
      });
    };

    const openAccordion = (details) => {
      const summary = details.querySelector('.footer-menu__summary');
      const list = details.querySelector('.footer-menu__list');
      if (!summary || !list) return;

      details.open = true;
      summary.setAttribute('aria-expanded', 'true');
      list.style.maxHeight = '0px';
      requestAnimationFrame(() => {
        list.style.maxHeight = `${list.scrollHeight}px`;
      });
    };

    const closeAccordion = (details) => {
      const summary = details.querySelector('.footer-menu__summary');
      const list = details.querySelector('.footer-menu__list');
      if (!summary || !list) return;

      summary.setAttribute('aria-expanded', 'false');
      list.style.maxHeight = `${list.scrollHeight}px`;
      requestAnimationFrame(() => {
        list.style.maxHeight = '0px';
      });

      list.addEventListener(
        'transitionend',
        () => {
          if (mediaQuery.matches && summary.getAttribute('aria-expanded') === 'false') {
            details.open = false;
          }
        },
        { once: true }
      );
    };

    accordions.forEach((details) => {
      const summary = details.querySelector('.footer-menu__summary');
      const list = details.querySelector('.footer-menu__list');
      if (!summary || !list) return;

      summary.addEventListener('click', (event) => {
        event.preventDefault();

        if (!mediaQuery.matches) {
          details.open = true;
          summary.setAttribute('aria-expanded', 'true');
          return;
        }

        if (summary.getAttribute('aria-expanded') === 'true') {
          closeAccordion(details);
        } else {
          openAccordion(details);
        }
      });

      list.addEventListener('transitionend', () => {
        if (mediaQuery.matches && details.open && summary.getAttribute('aria-expanded') === 'true') {
          list.style.maxHeight = `${list.scrollHeight}px`;
        }
      });
    });

    syncAccordions();
    if (mediaQuery.addEventListener) {
      mediaQuery.addEventListener('change', syncAccordions);
    } else {
      mediaQuery.addListener(syncAccordions);
    }
  })();
</script>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>High-quality, low-mileage units imported directly from Japan for unmatched performance and reliability.</p>"
        },
        {
          "type": "html",
          "id": "google_map_embed",
          "label": "Google map embed code",
          "default": "<iframe src=\"https://www.google.com/maps?q=5021%20Herzel%20Place%2C%20Beltsville%2C%20MD%2020705%2C%20USA&amp;output=embed\" loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\" title=\"Store location\"></iframe>",
          "info": "Paste the iframe embed code from Google Maps. Go to Google Maps > Share > Embed a map, then copy the HTML."
        }
      ]
    },
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "select",
          "id": "fallback_links",
          "label": "Fallback links",
          "default": "none",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "quick_links",
              "label": "Quick Links"
            },
            {
              "value": "policies",
              "label": "Policies"
            },
            {
              "value": "categories",
              "label": "Categories"
            }
          ]
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contact",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Get in Touch"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone",
          "default": "(301) 869-2400"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email",
          "default": "mdjdmmotors@gmail.com"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    },
    {
      "type": "header",
      "content": "Bottom"
    },
    {
      "type": "text",
      "id": "brand_tags",
      "label": "Brand tags",
      "default": "Honda, Mazda, Mitsubishi, Nissan, Subaru, Toyota, Acura, Infiniti, Lexus, Scion, Hyundai, Kia, CHEVROLET",
      "info": "Separate each brand tag with a comma. Each comma-separated value will appear as an individual tag."
    },
    {
      "type": "inline_richtext",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "© 2026 Powered by Drive Marketing. All Rights Reserved."
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 28
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "brand"
      },
      {
        "type": "menu",
        "settings": {
          "heading": "Quick Links",
          "fallback_links": "quick_links"
        }
      },
      {
        "type": "menu",
        "settings": {
          "heading": "Policies",
          "fallback_links": "policies"
        }
      },
      {
        "type": "menu",
        "settings": {
          "heading": "Categories",
          "fallback_links": "categories"
        }
      },
      {
        "type": "contact"
      }
    ]
  }
}
{% endschema %}
