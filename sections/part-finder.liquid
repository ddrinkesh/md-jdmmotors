{{ 'part-finder.css' | asset_url | stylesheet_tag }}
{{ 'custom-part-finder.js' | asset_url | script_tag }}

{%- style -%}
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top | times: 0.75 | round }}px;
      margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobi }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobi }}px;
    }
  }
{%- endstyle -%}

{% liquid
  assign vehicles = shop.metaobjects.part_finder_data.values
%}

<script>
  (function () {
    'use strict';

    var _sectionId_{{ section.id | handleize | replace: '-', '_' }}     = {{ section.id | json }};
    var _collectionUrl_{{ section.id | handleize | replace: '-', '_' }} = {% if section.settings.destination_collection != blank %}{{ section.settings.destination_collection.url | json }}{% else %}'/collections/all'{% endif %};

    /* ── Metaobject fallback data (inlined at render time) ── */
    var _fallbackData_{{ section.id | handleize | replace: '-', '_' }} = [
      {%- for vehicle in vehicles -%}
        {%- unless forloop.first -%},{%- endunless -%}
        {
          "brand": {{ vehicle.brand.value | default: '' | json }},
          "model": {{ vehicle.model.value | default: '' | json }},
          "year":  {{ vehicle.year.value  | default: '' | json }}
        }
      {%- endfor -%}
    ];

    function initInstance(data) {
      new window.PartFinder({
        sectionId:     _sectionId_{{ section.id | handleize | replace: '-', '_' }},
        collectionUrl: _collectionUrl_{{ section.id | handleize | replace: '-', '_' }},
        data:          data
      });
    }

    function loadData() {
      var jsonUrl = {{ 'part-finder-data.json' | asset_url | json }};

      fetch(jsonUrl)
        .then(function (res) {
          if (!res.ok) throw new Error('HTTP ' + res.status);
          return res.json();
        })
        .then(function (data) {
          if (!Array.isArray(data) || data.length === 0) throw new Error('Empty JSON asset');
          initInstance(data);
        })
        .catch(function (err) {
          console.warn('[PartFinder] JSON asset failed (' + err.message + '), using metaobject fallback.');
          initInstance(_fallbackData_{{ section.id | handleize | replace: '-', '_' }});
        });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', loadData);
    } else {
      loadData();
    }

    document.addEventListener('shopify:section:load', function (e) {
      if (e.detail.sectionId === _sectionId_{{ section.id | handleize | replace: '-', '_' }}) {
        loadData();
      }
    });

  })();
</script>

<div class="section-{{ section.id }} section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient section-main-box part-finder-section">
  <div class="part-finder page-width" data-section-id="{{ section.id }}">

    {% if section.settings.heading != blank or section.settings.heading_highlight != blank %}
      <div class="sec-head text-align-{{ section.settings.text_align }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">

        {% if section.settings.heading != blank %}
          <h2 class="sec-title">{{ section.settings.heading }}</h2>
        {%- endif -%}

      </div>
    {% endif %}

    <div class="part-finder__form {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="part-finder__selects">

        <div class="part-finder__select-wrap">
          <select class="part-finder__select" name="brand" autocomplete="off" aria-label="{{ section.settings.label_brands }}">
            <option value="">{{ section.settings.label_brands }}</option>
          </select>
          <span class="part-finder__caret">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
        </div>

        <div class="part-finder__select-wrap">
          <select class="part-finder__select" name="model" autocomplete="off" aria-label="{{ section.settings.label_model }}">
            <option value="">{{ section.settings.label_model }}</option>
          </select>
          <span class="part-finder__caret">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
        </div>

        <div class="part-finder__select-wrap">
          <select class="part-finder__select" name="year" autocomplete="off" aria-label="{{ section.settings.label_year }}">
            <option value="">{{ section.settings.label_year }}</option>
          </select>
          <span class="part-finder__caret">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
        </div>

      </div>

      <div class="btns-wrapper">
        <button type="button" class="button button--primary part-finder__btn">
          {{- section.settings.button_label | escape -}}
        </button>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Part Finder",
  "tag": "section",
  "class": "part-finder-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Highlighted text should be added in bold format, and the bold text will appear in red color."
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Labels"
    },
    {
      "type": "text",
      "id": "label_brands",
      "label": "Brands Label",
      "default": "Brands"
    },
    {
      "type": "text",
      "id": "label_model",
      "label": "Model Label",
      "default": "Model"
    },
    {
      "type": "text",
      "id": "label_year",
      "label": "Year Label",
      "default": "Year"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "FIND"
    },
    {
      "type": "header",
      "content": "Destination"
    },
    {
      "type": "collection",
      "id": "destination_collection",
      "label": "Destination Collection",
      "info": "Customers will be redirected here with vehicle filters applied. Falls back to /collections/all if not set."
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section Settings For Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobi",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobi",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Part Finder"
    }
  ]
}
{% endschema %}


