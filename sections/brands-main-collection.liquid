{{ 'brands-main-collection.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media screen and (max-width: 749px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobi }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobi }}px;
    }
  }

{%- endstyle -%}

<div class="section-{{ section.id }} section-{{ section.id }}-padding section-{{ section.id }}-margin color-{{ section.settings.color_scheme }} gradient section-main-box brands-main-collection-main">
  <div class="page-width">
    {% if section.settings.heading != blank or section.settings.sec_text != blank %}
      <div class="sec-head text-align-{{ section.settings.text_align }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {% if section.settings.heading != blank %}
          <h2 class="sec-title">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.sec_text != blank %}
          <div class="sec-text">{{ section.settings.sec_text }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="brands-main-collection-layout">
      <aside class="brands-main-collection-sidebar" aria-label="Brands">
        {% if section.settings.sidebar_heading != blank %}
          <h3 class="brands-main-collection-sidebar__title">{{ section.settings.sidebar_heading }}</h3>
        {% endif %}
        <div class="brands-main-collection-menu">
          <div class="brands-main-collection-menu__item is-active">
            <a href="/pages/honda" class="brands-main-collection-menu__link is-active">
              <span class="brands-main-collection-menu__brand">
                <span class="brands-main-collection-menu__logo">Honda</span>
                <span class="brands-main-collection-menu__name">Honda</span>
              </span>
              <span class="brands-main-collection-menu__arrow" aria-hidden="true">{{ 'icon-caret.svg' | inline_asset_content }}</span>
            </a>
            <div class="brands-main-collection-submenu">
              {% for block in section.blocks %}
                {% if block.type == 'category' and block.settings.show_in_sidebar %}
                  <a
                    {% if block.settings.link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.link }}"
                    {% endif %}
                    class="brands-main-collection-submenu__link"
                  >
                    <span class="brands-main-collection-submenu__image">
                      {% if block.settings.image != blank %}
                        {{ block.settings.image | image_url: width: 90 | image_tag: loading: 'lazy', class: 'brands-main-collection-submenu__img', widths: '45, 60, 90', alt: block.settings.title }}
                      {% endif %}
                    </span>
                    <span>{{ block.settings.title }}</span>
                  </a>
                {% endif %}
              {% endfor %}
            </div>
          </div>
          <div class="brands-main-collection-menu__item">
            <a href="/pages/mazda" class="brands-main-collection-menu__link">
              <span class="brands-main-collection-menu__brand">
                <span class="brands-main-collection-menu__logo">Mazda</span>
                <span class="brands-main-collection-menu__name">Mazda</span>
              </span>
              <span class="brands-main-collection-menu__arrow" aria-hidden="true">{{ 'icon-caret.svg' | inline_asset_content }}</span>
            </a>
          </div>
          <div class="brands-main-collection-menu__item">
            <a href="/pages/mitsubishi" class="brands-main-collection-menu__link">
              <span class="brands-main-collection-menu__brand">
                <span class="brands-main-collection-menu__logo">Mitsubishi</span>
                <span class="brands-main-collection-menu__name">Mitsubishi</span>
              </span>
              <span class="brands-main-collection-menu__arrow" aria-hidden="true">{{ 'icon-caret.svg' | inline_asset_content }}</span>
            </a>
          </div>
          <div class="brands-main-collection-menu__item">
            <a href="/pages/nissan" class="brands-main-collection-menu__link">
              <span class="brands-main-collection-menu__brand">
                <span class="brands-main-collection-menu__logo">Nissan</span>
                <span class="brands-main-collection-menu__name">Nissan</span>
              </span>
              <span class="brands-main-collection-menu__arrow" aria-hidden="true">{{ 'icon-caret.svg' | inline_asset_content }}</span>
            </a>
          </div>
          <div class="brands-main-collection-menu__item">
            <a href="/pages/subaru" class="brands-main-collection-menu__link">
              <span class="brands-main-collection-menu__brand">
                <span class="brands-main-collection-menu__logo">Subaru</span>
                <span class="brands-main-collection-menu__name">Subaru</span>
              </span>
              <span class="brands-main-collection-menu__arrow" aria-hidden="true">{{ 'icon-caret.svg' | inline_asset_content }}</span>
            </a>
          </div>
          <div class="brands-main-collection-menu__item">
            <a href="/pages/toyota" class="brands-main-collection-menu__link">
              <span class="brands-main-collection-menu__brand">
                <span class="brands-main-collection-menu__logo">Toyota</span>
                <span class="brands-main-collection-menu__name">Toyota</span>
              </span>
              <span class="brands-main-collection-menu__arrow" aria-hidden="true">{{ 'icon-caret.svg' | inline_asset_content }}</span>
            </a>
          </div>
          <div class="brands-main-collection-menu__item">
            <a href="/pages/acura" class="brands-main-collection-menu__link">
              <span class="brands-main-collection-menu__brand">
                <span class="brands-main-collection-menu__logo">Acura</span>
                <span class="brands-main-collection-menu__name">Acura</span>
              </span>
              <span class="brands-main-collection-menu__arrow" aria-hidden="true">{{ 'icon-caret.svg' | inline_asset_content }}</span>
            </a>
          </div>
          <div class="brands-main-collection-menu__item">
            <a href="/pages/infiniti" class="brands-main-collection-menu__link">
              <span class="brands-main-collection-menu__brand">
                <span class="brands-main-collection-menu__logo">Infiniti</span>
                <span class="brands-main-collection-menu__name">Infiniti</span>
              </span>
              <span class="brands-main-collection-menu__arrow" aria-hidden="true">{{ 'icon-caret.svg' | inline_asset_content }}</span>
            </a>
          </div>
          <div class="brands-main-collection-menu__item">
            <a href="/pages/lexus" class="brands-main-collection-menu__link">
              <span class="brands-main-collection-menu__brand">
                <span class="brands-main-collection-menu__logo">Lexus</span>
                <span class="brands-main-collection-menu__name">Lexus</span>
              </span>
              <span class="brands-main-collection-menu__arrow" aria-hidden="true">{{ 'icon-caret.svg' | inline_asset_content }}</span>
            </a>
          </div>
        </div>
      </aside>

      <div class="brands-main-collection-content">
        {% for block in section.blocks %}
          {% if block.type == 'category' and block.settings.show_tile %}
            <a
              {% if block.settings.link == blank %}
                role="link" aria-disabled="true"
              {% else %}
                href="{{ block.settings.link }}"
              {% endif %}
              class="brands-main-collection-tile{% if block.settings.featured_tile %} brands-main-collection-tile--featured{% endif %}"
              {{ block.shopify_attributes }}
            >
              <span class="brands-main-collection-tile__media">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'brands-main-collection-tile__image', widths: '320, 480, 640, 800, 1000, 1200', sizes: '(min-width: 990px) 40vw, (min-width: 750px) 50vw, 100vw', alt: block.settings.title }}
                {% else %}
                  {{ 'collection-apparel-1' | placeholder_svg_tag: 'placeholder-svg brands-main-collection-tile__image' }}
                {% endif %}
                <span class="brands-main-collection-tile__overlay" aria-hidden="true"></span>
              </span>
              <span class="brands-main-collection-tile__title">{{ block.settings.title }}</span>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Brands Main Collection",
  "tag": "section",
  "class": "brands-main-collection-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "sec_text",
      "label": "Content"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Sidebar"
    },
    {
      "type": "inline_richtext",
      "id": "sidebar_heading",
      "label": "Sidebar heading",
      "default": "Brands"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section Settings For Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobi",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobi",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "show_in_sidebar",
          "label": "Show in sidebar",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_tile",
          "label": "Show tile",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "featured_tile",
          "label": "Featured tile",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brands Main Collection",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Engines",
            "link": "/pages/honda-engines",
            "featured_tile": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
